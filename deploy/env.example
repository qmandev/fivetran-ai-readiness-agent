# Copy to .env and fill. Never commit the filled .env.

# Fivetran API credentials — generate at:
# https://fivetran.com/dashboard/user/api-config
FIVETRAN_API_KEY=
FIVETRAN_API_SECRET=

# Secret used to HMAC-sign webhook payloads (set when creating the webhook).
FIVETRAN_WEBHOOK_SECRET=

# BigQuery
GCP_PROJECT_ID=
BQ_STATE_DATASET=agent_state   # our DOMAIN state (snapshots, drift_events)
                               # NOTE: distinct from the observability dataset
                               # agents-cli `infra single-project` provisions
BQ_DESTINATION_DATASET=        # the dataset Fivetran lands data into

# Gemini Enterprise Agent Platform / ADK (per onboarding guide)
GOOGLE_CLOUD_PROJECT=          # usually same as GCP_PROJECT_ID
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=TRUE
# Auth: prefer ADC — `gcloud auth application-default login`
#       then `gcloud auth application-default set-quota-project $GCP_PROJECT_ID`

# Agent
AUTONOMY_LEVEL=STRICT          # STRICT | TRUSTED_ADDITIVE | FULL_AUTO
